# Secret used to sign and validate booking QR tokens.
QR_SECRET=replace-with-production-strong-random-secret

# Firebase Storage bucket used by listing moderation image review/copy flows.
LEND_FIREBASE_STORAGE_BUCKET=lend-api.firebasestorage.app

# Firebase project ID used by local scripts/emulator helpers.
PROJECT_ID=lend-api

# Cloud Functions deployment region. Singapore is nearest to the Philippines
# and matches the production Firestore database region.
FUNCTIONS_REGION=asia-southeast1

# Set true only when intentionally running local backfill scripts.
RUN_BACKFILL=false

# Production deploys must not run emulator behavior.
FUNCTIONS_EMULATOR=false

# Didit webhook signing secret from the Didit Console.
# Required only when diditVerificationWebhook is deployed/enabled.
DIDIT_WEBHOOK_SECRET_KEY=replace-with-production-didit-webhook-secret

# Optional. Leave blank to derive the regional Firebase Functions URL.
DECLINE_FUNCTIONS_URL=

PAYMONGO_SECRET_KEY=sk_live_replace_with_production_secret_key
PAYMONGO_PUBLIC_KEY=pk_live_replace_with_production_public_key
PAYMONGO_PAYOUT_CALLBACK_URL=https://replace-with-production-payout-callback-url
PAYMONGO_WEBHOOK_SECRET=replace-with-production-paymongo-webhook-secret
PAYMONGO_WALLET_ID=replace-with-production-wallet-id
PAYMONGO_RETURN_URL=https://getlend.dev/payment/return

# Public web app base URL used to generate shareable listing links.
LEND_WEB_BASE_URL=https://getlend.dev
PAYMONGO_PAYMENT_METHODS=

# Resend transactional email configuration.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Lend <no-reply@getlend.dev>
RESEND_REPLY_TO_EMAIL=
EMAIL_VERIFICATION_BASE_URL=https://getlend.dev/email/verify

# Listing moderation.
# Set OPENAI_API_KEY as a Firebase secret or runtime env var in production.
OPENAI_API_KEY=
OPENAI_MODERATION_MODEL=omni-moderation-latest

# Gemini/Genkit listing business-quality review.
# Set GEMINI_API_KEY as a Firebase secret or runtime env var in production.
GEMINI_API_KEY=
LISTING_REVIEW_MODEL=gemini-2.5-flash-lite
