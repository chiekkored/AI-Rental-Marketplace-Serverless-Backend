rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    function isSelf(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /{userId}/posts/images/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId}/listingDrafts/{draftId}/images/{fileName} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/listingDeactivationRequests/{requestId}/evidence/{fileName} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId}/businessRegistration/{fileName} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId || request.auth.token.admin == true);
      allow write: if isSelf(userId);
    }

    match /listings/{listingId}/images/{fileName} {
      allow read: if true;
      allow write: if false;
    }

    match /{userId}/profile/photos/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /{userId}/chats/{chatId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /{userId}/bookings/{bookingId}/damage-evidence/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
